    <div class="achievement fade-in">
      <div class="achievement-icon">🏅</div>
      <div>
        <div class="achievement-name">Champion AEC — All Élite Combat</div>
        <div class="achievement-detail">Ceinture de la ligue française d'élite</div>
      </div>
      <div class="achievement-year">2023</div>
    </div>
    <div class="achievement fade-in">
      <div class="achievement-icon">⚡</div>
      <div>
        <div class="achievement-name">Professionnel Invaincu — 3 combats, 3 KO/TKO</div>
        <div class="achievement-detail">Hexagone MMA · 100% de finishes en carrière pro</div>
      </div>
